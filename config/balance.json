{
  // ── 난이도 성장률 (docs/HOW-TO-GAMEDESIGN.md §2 참조) ────────────────────────────
  // 층당 몹 HP가 늘어나는 비율. 공식: floorHpMult(층) = 1 + (층-1) × floorHpGrowth.
  // 단위: 비율(1층 대비 배수 증분). 0 이상의 숫자만 허용(음수/NaN이면 경고 후 기본값 0.08로 대체).
  // 권장범위: 0.03~0.15 (낮을수록 완만, 높을수록 층이 올라갈수록 몹이 급격히 단단해짐). 예: 0.08 → 10층에서 HP ×1.72.
  "floorHpGrowth": 0.08,
  // 층당 EXP·골드가 늘어나는 비율. 공식 동일: floorRewardMult(층) = 1 + (층-1) × floorRewardGrowth.
  // 단위: 비율. 0 이상의 숫자만 허용. 권장범위: 0.03~0.12(기본 0.06, HP 성장보다 완만하게 잡는 것을 권장).
  "floorRewardGrowth": 0.06,
  // 히어로 자동 우측전진 속도. 단위: world px/초. 0보다 큰 숫자만 허용(그 외 값이면 경고 후 기본 45로 대체).
  // 값이 클수록 화면을 빨리 가로지르며 몬스터 조우 빈도가 올라간다. 권장범위: 30~70(기본 45).
  "advanceSpeed": 45,
  // 몬스터가 스폰 후 히어로 쪽으로 걸어서 접근하는 속도(encounterGap 거리에 도달하면 멈추고 전투 시작).
  // 단위: world px/초. 0보다 큰 숫자만 허용. advanceSpeed보다 약간 느리게 잡아야("서로 다가가는" 리듬)
  // 자연스럽다 — 권장: advanceSpeed의 70~85%(기본 35 = 45의 약 78%). walk 시트 없는 몬스터는 idle
  // 자세로 슬라이드 이동한다.
  "monsterApproachSpeed": 35,
  // 몬스터 id별 HP/공격력 배수 — 특정 종만 세게(또는 약하게) 만들고 싶을 때 사용.
  // 등록 안 된 몬스터 id는 자동으로 hpMult=1.0/atkMult=1.0(보정 없음) 취급된다.
  // 최종 몬스터 HP = getMonsterHp(레벨) × floorHpMult(층) × dungeon.hpMult × 여기 hpMult.
  // 최종 몬스터 공격력 배수 = dungeon.atkMult × 여기 atkMult.
  "monsters": {
    // mushroom(버섯): 기본 몬스터보다 체력 20% 높고(hpMult) 공격력 10% 낮게(atkMult) — "튼튼하지만 순한" 몹 컨셉.
    "mushroom": {
      // 0보다 큰 숫자만 허용(그 외 값이면 경고 후 1.0으로 대체). 1.0=기본, 1.2=20%↑.
      "hpMult": 1.2,
      // 0보다 큰 숫자만 허용. 1.0=기본, 0.9=10%↓.
      "atkMult": 0.9
    }
  },
  // ── 화면 배치(히어로/몬스터 위치·크기) — docs/HOW-TO-GAMEDESIGN.md §2-1 참조 ──────────────
  "layout": {
    // 히어로가 화면 가로 어디에 고정되는지(카메라 기준점). 0=화면 왼쪽 끝, 1=오른쪽 끝, 비율.
    // 0~1 사이 숫자만 허용(벗어나면 경고 후 기본 0.35로 대체). 기본 0.35(좌측 1/3 지점).
    "heroScreenX": 0.35,
    // 지면(발끝 기준선)이 화면 세로 어디인지. 0=화면 위, 1=아래, 비율. 0~1 사이 숫자만 허용.
    // 기본 0.72(화면 하단에서 살짝 위).
    "groundYRatio": 0.72,
    // 히어로만 위아래로 미세조정. 단위: world px, 양수(+)면 아래로 이동. 임의의 유한 숫자 허용(음수 가능).
    // 기본 0(보정 없음). 시트 여백 때문에 발끝이 뜨거나 파묻힐 때 조정.
    "heroYOffset": 20,
    // 몬스터 전체(일반+보스 공통)를 위아래로 미세조정. 단위: world px, +아래. 임의의 유한 숫자 허용.
    // 기본 0. 특정 종만 따로 조정하려면 아래 layout.monsters.<id>.yOffset을 쓴다(이 전역값에 추가로 더해짐).
    "monsterYOffset": 20,
    // 히어로가 일반몹과 몇 world px 거리(중심 간)에서 멈춰 전투를 시작하는지(보스는 아래
    // bossEncounterGap이 있으면 그걸 대신 씀). 0보다 큰 숫자만 허용. 값이 클수록 더 멀리서
    // 교전을 시작한다. 기본 52.
    "encounterGap": 25,
    // 보스전 전용 조우 정지거리(world px). 생략/미지정이면 위 encounterGap을 그대로 상속.
    // 보스는 일반몹보다 스프라이트가 커서(scale 1.5 관례) 일반몹과 같은 거리로 붙으면
    // 화면이 꽉 차 보여 이 값을 따로 키운다. 0보다 큰 숫자만 허용, 그 외 값이면 경고 후
    // encounterGap 상속으로 대체. 기본 80(실기로 보스 크기 대비 자연스러운 값으로 조정됨).
    // 몬스터별로 더 세밀하게 조정하려면 아래 layout.monsters.<id>.encounterGap을 쓴다
    // (개별 지정이 있으면 이 값보다 우선).
    "bossEncounterGap": 80,
    // 히어로 전체 표시 배율. 0보다 큰 숫자만 허용. 1.0=원본 크기. 기본 1.8(권장 게임뷰 배율).
    "heroScale": 2,
    // 몬스터 전역(일반+보스 공통) 표시 배율. 0보다 큰 숫자만 허용. 1.0=원본 비율 그대로. 기본 1.0.
    "monsterScale": 1,
    // 히어로 스프라이트 도트(픽셀) 굵기 배율 — 로드된 시트를 1/N로 다운샘플 후 nearest로 재확대해
    // 표시 크기(heroScale)는 그대로 두고 도트만 N배 굵게 만든다(작은 시트를 다시 그리지 않고 도트
    // 느낌을 강화하는 용도). 0보다 큰 숫자만 허용, 정수 1~4 권장(그 외 값도 동작은 하지만 효과가
    // 미미하거나 도트가 과하게 뭉개질 수 있어 소프트 경고만 남음). 기본 1(원본 그대로).
    "heroPixelScale": 4,
    // (참고) 몬스터 전역 도트 굵기 배율은 layout.monsterPixelScale 필드로 지정 가능(미지정 시 기본 1) —
    // 이 파일에는 현재 지정돼 있지 않으므로 기본값 1이 적용되고, 아래 monsters.<id>.pixelScale로
    // 종별 값(3)이 개별 지정돼 있다. 0보다 큰 숫자만 허용, 정수 1~4 권장.
    // 히어로 HP바(+마나바, 같이 움직임) 세로 미세조정(world px, +아래/-위). 임의의 유한 숫자
    // 허용(음수 가능). 기본 0(보정 없음). docs/HOW-TO-GAMEDESIGN.md §layout 참조.
    "heroHpBarYOffset": 0,
    // 일반 몬스터(보스 아님) 머리 위 HP바 전역 세로 미세조정(world px, +아래/-위). 임의의
    // 유한 숫자 허용. 기본 0. 몬스터별로 더 조정하려면 아래 monsters.<id>.hpBarYOffset을
    // 쓴다(이 전역값에 가산됨). 보스는 이 바 자체가 숨겨져 있어 영향 없음.
    "monsterHpBarYOffset": 0,
    // 몬스터 id별 화면 위치·크기·도트굵기·조우거리·HP바위치 개별 보정 — 시트마다 여백/비율이
    // 조금씩 달라 발끝 정렬이 안 맞을 때, 또는 특정 종만 조우거리/HP바 위치를 다르게 하고
    // 싶을 때 종 단위로 미세조정한다. 등록 안 된 몬스터는 yOffset=0, scale=1.0,
    // pixelScale=layout.monsterPixelScale(전역값 상속), encounterGap=미지정(보스면
    // bossEncounterGap, 아니면 encounterGap 그대로), hpBarYOffset=0(전역값만 적용)이 적용된다.
    // encounterGap 필드(선택, 0보다 큰 숫자만 허용): 이 몬스터만의 조우 정지거리(일반/보스
    // 공통) — 지정하면 위 bossEncounterGap/encounterGap보다 최우선으로 적용된다. 예:
    // "spiderking": { "encounterGap": 100 }를 추가하면 다른 보스는 bossEncounterGap(80)을
    // 쓰되 spiderking만 100을 쓴다.
    // hpBarYOffset 필드(선택, 임의의 유한 숫자, +아래/-위): 이 몬스터만의 머리 위 HP바
    // 세로 미세조정 — 위 monsterHpBarYOffset(전역)에 가산된다(개별 지정 없으면 전역값만 적용).
    "monsters": {
      "mushroom": {
        // 이 종만 위아래 추가 미세조정(world px, +아래). monsterYOffset(전역)에 더해짐. 임의의 유한 숫자.
        "yOffset": 12,
        // 이 종만 크기 배율(monsterScale 전역에 곱해짐 아님 — BOSS/NORMAL 렌더높이 자체에 곱해지는 개별 배율). 0보다 큰 숫자만 허용. 기본 1.0.
        "scale": 1,
        // 이 종만 도트 굵기(정수 1~4 권장). 지정 없으면 전역 monsterPixelScale 상속.
        "pixelScale": 3,
        "hpBarYOffset": -10
      },
      "slime": {
        "yOffset": -2,
        "scale": 1,
        "pixelScale": 5,
        "hpBarYOffset": 10
      },
      "snail": {
        "yOffset": 12,
        "scale": 1,
        "hpBarYOffset": -10
      },
      "spider": {
        "yOffset": 12,
        "scale": 1,
        "hpBarYOffset": -10
      },
      // spiderking(스파이더킹, 보스): scale 1.5 = 보스 표준 확대 비율(일반 몬스터의 1.5배 관례 유지).
      "spiderking": {
        "yOffset": 30,
        "scale": 1.5,
        "pixelScale": 3
      }
    }
  },
  // ── 주인공(hero) 밸런스 — docs/HOW-TO-GAMEDESIGN.md, packages/core/src/heroBalance.ts 참조 ──
  "hero": {
    // 스탯과 무관한 히어로 기본치(레벨/스탯 0 기준 베이스라인).
    "base": {
      // 최대 HP 기본값(VIT=0 기준). 최종 HP = hp + VIT × perStat.vitHp. 0보다 큰 숫자만 허용. 기본 50.
      "hp": 50,
      // 최대 마나 기본값(WIS=0 기준). 최종 마나 = mana + WIS × perStat.wisMana. 0 이상 숫자만 허용. 기본 20.
      "mana": 20,
      // 크리티컬 확률 기본치(%, LUK=0 기준, /100 하기 전 값). 최종 = min(caps.critChanceMaxPct,
      // critChancePct + LUK × perStat.lukCritChancePct). 0 이상 숫자만 허용. 기본 5(=5%).
      "critChancePct": 5,
      // 크리티컬 배율 기본치(LUK=0 기준, 배율값 그 자체 — 추가 /100 없음). 0보다 큰 숫자만 허용.
      // 1.5 = 크리티컬 시 150% 피해. 기본 1.5.
      "critMult": 1.5,
      // 공격 쿨다운 기본치(ms, DEX=0 기준). 최종 = clamp(attackCdMinMs, attackCdMs - DEX×perStat.dexAttackCdMs, attackCdMs).
      // 단위: ms. 0보다 큰 숫자만 허용. 코드 기본값은 700이나 이 파일(오너 편집값)은 3000으로
      // 설정돼 있음 — 값이 클수록 평타 주기가 느려진다.
      "attackCdMs": 1200,
      // 공격 쿨다운 하한(ms) — DEX가 아무리 높아도 이 아래로는 안 내려감. 0보다 큰 숫자만 허용. 기본 240.
      "attackCdMinMs": 240,
      // 골드 획득 배율 기본치(CHA/LUK=0 기준). 최종 = goldMult + CHA×perStat.chaGoldMult + (LUK-1)×perStat.lukGoldMult.
      // 0보다 큰 숫자만 허용. 1.0=기본(배수 없음). 기본 1.
      "goldMult": 1,
      // 몬스터→히어로 기본 피해(레벨=0 기준). 최종 = monsterAtk + floor(레벨×monsterAtkPerLevel). 단위: 피해량.
      // 0 이상 숫자만 허용. 기본 3.
      "monsterAtk": 3,
      // 몬스터 공격력의 레벨당 증가량(위 monsterAtk 공식에 사용). 0 이상 숫자만 허용. 기본 0.5.
      "monsterAtkPerLevel": 0.5,
      // 보스 몬스터 공격력 배율(일반 몬스터 대비 몇 배로 때리는지). 0보다 큰 숫자만 허용. 기본 3(=3배).
      "monsterBossAtkMult": 3,
      // 전투 중 초당 HP 자연 회복 비율(최대HP 대비 비율/초, 0.01=초당 1%). 0 이상 숫자만 허용. 기본 0.01.
      "hpRegenRatePerSec": 0.01
    },
    // 스탯 1포인트당 효과 계수 — STR/DEX/VIT/INT/WIS/CHA/LUK 각 스탯이 실제 전투 수식에 미치는 영향.
    // 모든 필드 0 이상 숫자만 허용(그 외면 경고 후 기본값으로 대체).
    "perStat": {
      // STR → 물리 공격력(전사류 주력 스탯). physAtk = floor(STR × strAtk). 기본 0.6.
      "strAtk": 0.6,
      // DEX → 물리 공격력(도적/궁수류 보조 계수). physAtkDex = floor(DEX × dexAtk). 기본 0.5.
      "dexAtk": 0.5,
      // DEX → 공격 쿨다운 감소량(ms/포인트, attackCdMinMs가 하한). 기본 10.
      "dexAttackCdMs": 10,
      // DEX → 회피율 증가량(%p/포인트, /100 전, caps.dodgeMaxPct로 상한). 기본 0.5.
      "dexDodgePct": 0.5,
      // VIT → 최대 HP 증가량(포인트당). 기본 10.
      "vitHp": 10,
      // VIT → 받는 피해 감소율(%p/포인트, /100 전, caps.dmgReductionMaxPct로 상한). 기본 0.4.
      "vitDmgReductionPct": 0.4,
      // INT → 마법 공격력(마법사류 주력 스탯). magicAtk = floor(INT × intAtk). 기본 0.8.
      "intAtk": 0.8,
      // WIS → 스킬 피해 배율 증가(fraction/포인트, /100 없음). skillMult = 1 + WIS × wisSkillMult. 기본 0.03.
      "wisSkillMult": 0.03,
      // WIS → 스킬 재사용 대기시간 감소(fraction/포인트, /100 없음, caps.skillCdMax로 상한). 기본 0.015.
      "wisSkillCd": 0.015,
      // WIS → 최대 마나 증가량(포인트당). 기본 5.
      "wisMana": 5,
      // CHA → 골드 획득 배율 증가(fraction/포인트, /100 없음). 기본 0.02.
      "chaGoldMult": 0.02,
      // CHA → 상점 할인율 증가(%p/포인트, /100은 가격계산 시 적용, caps.shopDiscountMaxPct로 상한). 기본 0.5.
      "chaShopDiscountPct": 0.5,
      // LUK → 크리티컬 확률 증가(%p/포인트, /100 전, caps.critChanceMaxPct로 상한). 기본 1.0.
      "lukCritChancePct": 1.0,
      // LUK → 크리티컬 배율 증가(fraction/포인트, /100 없음). 기본 0.02.
      "lukCritMult": 0.02,
      // LUK(1 초과분) → 골드 획득 배율 증가(fraction/포인트). goldMult += (LUK-1) × lukGoldMult. 기본 0.03.
      "lukGoldMult": 0.03
    },
    // 스탯 효과 상한(캡) — 위 perStat 계수가 아무리 쌓여도 이 값을 넘지 못한다. 모두 0 이상 숫자만 허용.
    "caps": {
      // 회피율 상한(%, /100 전). 기본 35(=최대 35% 회피).
      "dodgeMaxPct": 35,
      // 받는 피해 감소 상한(%, /100 전). 기본 40(=최대 40% 경감).
      "dmgReductionMaxPct": 40,
      // 스킬 쿨다운 감소 상한(fraction, /100 없음 — 0.5=최대 50% 단축). 기본 0.5.
      "skillCdMax": 0.5,
      // 크리티컬 확률 상한(%, /100 전). 기본 60(=최대 60%).
      "critChanceMaxPct": 60,
      // 상점 할인율 상한(%, /100은 가격계산 시). 기본 30(=최대 30% 할인).
      "shopDiscountMaxPct": 30
    },
    // 레벨업 관련 계수 — 0 이상 숫자만 허용.
    "leveling": {
      // EXP 곡선 1차항 계수. expToNext(레벨) = 레벨×expPerLevel + 레벨²×expPerLevelSq. 기본 120.
      "expPerLevel": 120,
      // EXP 곡선 2차항 계수(레벨이 올라갈수록 필요 경험치가 가속 증가). 기본 6.
      "expPerLevelSq": 6,
      // 레벨업 1회당 지급되는 스탯 포인트 수. 기본 3.
      "statPointsPerLevel": 3
    },
    // 스킬 시스템 공용 계수(스킬별 dmgMult 카탈로그 자체는 balance.json 범위 밖 — @levup/core/skill.ts).
    "skills": {
      // 평타 1회 적중 시 회복되는 마나량. 0 이상 숫자만 허용. 기본 5.
      "manaRegenPerHit": 5,
      // SkillDef.dmgMult 미지정 시 사용하는 기본 배율. 0보다 큰 숫자만 허용. 기본 1.0.
      "defaultDmgMult": 1.0
    }
  },
  // ── 애니메이션 재생 속도 — docs/HOW-TO-GAMEDESIGN.md, huntFieldMath.ts clampHeroAttackFps 참조 ──
  // 모든 필드 단위: fps(초당 프레임). 0보다 큰 숫자만 허용(그 외면 경고 후 기본값 대체).
  // attack류(1회성 사이클)는 fps를 낮출수록 사이클이 길어지는데, 그 사이클이 공격 쿨타임(hero.base.attackCdMs
  // 등)보다 길어지면 다음 공격과 겹치지 않도록 게임이 자동으로 쿨타임에 맞춰 클램프한다(콘솔 안내 1회).
  "animation": {
    // 히어로 대기(idle) 8프레임 루프 재생 속도. 기본 8.
    "heroIdleFps": 8,
    // 히어로 이동(walk) 8프레임 루프 재생 속도. 기본 12.
    "heroWalkFps": 12,
    // 히어로 공격(attack) 8프레임 1사이클 재생 속도. 낮출수록 스윙이 느려 보인다. 기본 24.
    "heroAttackFps": 12,
    // 몬스터 대기(idle) 루프 재생 속도. 기본 8.
    "monsterIdleFps": 8,
    // 몬스터 접근 이동(walk) 루프 재생 속도. 기본 10.
    "monsterWalkFps": 10,
    // 몬스터 공격(런지+복귀) 애니메이션 재생 속도(기준값 24 대비 상대 배율로 지속시간에 반영).
    // 기본 24(= 현재 정상몹 120/160ms, 보스 180/220ms 런지/복귀 지속시간 그대로).
    "monsterAttackFps": 24
  }
}

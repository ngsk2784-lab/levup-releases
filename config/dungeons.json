{
  // dungeons.json — 던전(테마)/몬스터 스폰/보스/난이도 배율 오너 편집 파일.
  // docs/HOW-TO-GAMEDESIGN.md §1 참조. 몬스터 id는 반드시 monster-manifest.json에 먼저
  // 등록돼 있어야 한다(docs/HOW-TO-ADD-MONSTERS.md) — 없으면 콘솔 경고 후 스킵(게임은 안 죽음).
  "dungeons": [
    {
      // 던전 고유 id(영문, 중복 불가). 코드/세이브에서 이 던전을 식별하는 키.
      "id": "forest",
      // 화면에 표시되는 던전 이름(층 HUD, 보스 등장 토스트 등).
      "name": "초보자의 숲",
      // "시작층-끝층" 형식 문자열. 던전들은 이 구간 순서대로 이어지며, 마지막 던전의 끝층을
      // 넘으면 등록된 던전 전체를 처음부터 다시 순환한다(예: 이 던전만 있으면 무한 반복).
      "floors": "1-1",
      // public/assets/maple/bg/ 기준 배경 파일명. <이름>_L0/_L1/_L2.png 3장이 모두 있으면
      // 자동으로 패럴랙스 배경으로 그려지고, 없으면 이 단일 파일을 그대로 쓴다. 파일이 없으면
      // 기본 배경으로 자동 대체되고 경고가 뜬다.
      "bg": "forest.png",
      // 이 던전(층별 floorOverrides가 없는 층)에서 스폰되는 일반 몬스터 목록과 상대 가중치.
      // id는 monster-manifest.json에 등록된 몬스터 id, weight는 클수록 자주 나옴(비율 계산,
      // 절대값 아님 — 예: 60/40이면 슬라임이 60%, 버섯이 40% 확률).
      "monsters": [
        //{ "id": "slime", "weight": 0 },
        //{ "id": "mushroom", "weight": 0 },
        //{ "id": "snail", "weight": 0 },
        //{ "id": "spider", "weight": 0 }
      ],
      // 이 던전의 보스로 고정 스폰되는 몬스터 id(monsters 목록과 무관하게 지정 가능, 독립 보스
      // bossOnly 몬스터도 가능). monster-manifest.json에 없으면 경고 후 일반 스폰 풀의 첫
      // 항목으로 자동 대체된다.
      "boss": "spiderking",
      // 이 던전에서 층당 처치해야 하는 일반몹 수(달성 시 보스 게이트가 열림). 생략 시 기본 8.
      "mobsPerFloor": 4,
      // 몬스터 스폰 시작 x좌표(히어로 기준 world px 거리) — 값이 작을수록 몬스터가 더 가까이서
      // 나타난다. 생략 시 화면 폭 비례(worldW×0.55)로 자동 계산.
      "spawnDistance": 150,
      // 이 던전 전체 몬스터에 곱해지는 HP 배수. 1.0=배수 없음(기본값). balance.json의
      // monsters.<id>.hpMult와 곱해져 최종 HP 배수가 된다.
      "hpMult": 1.0,
      // 이 던전 전체 몬스터에 곱해지는 공격력 배수. 1.0=배수 없음(기본값). balance.json의
      // monsters.<id>.atkMult와 곱해진다.
      "atkMult": 1.0,
      // 이 던전에서 얻는 EXP·골드에 곱해지는 배수. 1.0=배수 없음(기본값).
      "rewardMult": 1.0,
      // 층별 오너 편집 오버라이드 — 특정 층(전역 층 번호, 문자열 키)에서만 monsters/
      // spawnDistance/mobsPerFloor를 던전 기본값 위에 덮어쓴다. 세 필드 모두 선택이며,
      // 지정된 필드만 대체하고 나머지는 던전 기본값을 그대로 쓴다.
      "floorOverrides": {
        // 1층에서만: 스폰 몬스터 풀을 달팽이/거미로 교체, 스폰거리 100(더 가깝게), 층당 5마리로 변경.
        "1": {
          "monsters": [
            { "id": "slime", "weight": 1 },
            { "id": "mushroom", "weight": 1 },
            { "id": "snail", "weight": 100 },
            { "id": "spider", "weight": 1 }
          ],
          "spawnDistance": 100,
          "mobsPerFloor": 2
        }
      }
    }
  ]
}
